# Copy to .env.local and fill in (never commit .env.local).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: Supabase service_role JWT — required for Stripe webhooks (insert into `purchases`).
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One-time Prices from Products, e.g. price_xxxxx
STRIPE_PRICE_SINGLE=
STRIPE_PRICE_BUNDLE=
# $7 single-city "Should we move here?" report
STRIPE_PRICE_SINGLE_CITY=

# Optional: canonical URL for Checkout return/cancel (prod default is https://famirelo.com)
# NEXT_PUBLIC_SITE_URL=https://famirelo.com

RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# ── Freshness admin (server-only) ────────────────────────────────────────────
# Comma-separated allowlist of emails that can access /admin/freshness.
# Anyone else gets a 404 (never a redirect, no leak of the route).
ADMIN_EMAILS=

# GitHub PAT used by the admin dashboard to commit `cities.json` updates
# (mark-reviewed) and revert past edits. Needs `contents:write` on the repo.
GITHUB_REVIEW_TOKEN=
# owner/repo, e.g. "eladsh/relocation-engine"
GITHUB_REPO=
# Optional — defaults to "main"
# GITHUB_BRANCH=main

# ── Content scanner (LLM-powered) ────────────────────────────────────────────
# Master kill switch for the monthly scheduled scan. When false, the cron
# returns immediately and spends $0. Manual "Scan now" still works.
SCAN_ENABLED=false

# OpenAI API key — get one at https://platform.openai.com/api-keys.
# Without this, scans return nothing and the dashboard keeps showing demo data.
OPENAI_API_KEY=
# Optional: defaults to gpt-4o-mini (cheapest model that handles this well).
# OPENAI_MODEL=gpt-4o-mini

# Per-section toggles. Default false. Master switch must also be true.
# SCAN_VISA=false
# SCAN_HOUSING=false
# SCAN_HEALTHCARE=false
# SCAN_SAFETY=false
# SCAN_SCHOOLS=false
# SCAN_CHILDCARE=false
# SCAN_COST=false
# SCAN_RESIDENCY=false
# SCAN_BANKING=false

# Optional shared secret to manually call /api/admin/scan/cron?secret=...
# (Vercel cron uses its own header — this is just for local testing.)
CRON_SECRET=
